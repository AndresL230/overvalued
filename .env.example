# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.
#
#   cp .env.example .env.local
#
# Restart `npm run dev` after editing — Next only reads .env.local at boot.

# --- Supabase (local) -------------------------------------------------------
# These are the default local dev values printed by `npx supabase start`.
# Run `npx supabase status` if yours differ.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# --- Résumé desk (optional) -------------------------------------------------
# Powers the 🎲 button. Get a key at https://aistudio.google.com/apikey
# WITHOUT this the game still works — the dice falls back to the local
# wordlist generator and shows "résumé desk offline".
# Server-side only: never prefix this with NEXT_PUBLIC_.
GEMINI_API_KEY=

# Optional override if the model name changes.
# GEMINI_MODEL=gemini-2.5-flash
